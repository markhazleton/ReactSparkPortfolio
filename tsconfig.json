{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "jsx": "react-jsx",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true, // Enables faster builds with incremental compilation
    "noEmit": true, // Prevents emitting files during 'npm run dev'
    "types": ["vitest/globals"]
  },
  "include": ["src", "tests", "vitest.config.ts"],
  "exclude": ["node_modules", "docs"] // Updated to exclude docs instead of dist
}
